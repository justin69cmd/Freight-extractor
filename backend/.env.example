# Copy to .env and fill in. All vars are prefixed FREIGHT_.
# Defaults below = native local mode (SQLite + in-process jobs, no Docker).
# Docker/production overrides DATABASE_URL/REDIS/JOB_EXECUTOR via compose.
FREIGHT_ENVIRONMENT=development
FREIGHT_DEBUG=true

# Persistence — SQLite file for local mode (zero install). For Postgres use e.g.
# postgresql+psycopg://freight:freight@localhost:5432/freight
FREIGHT_DATABASE_URL=sqlite:///./freight.db

# Job execution — "thread" (local, no broker) or "celery" (needs Redis + worker)
FREIGHT_JOB_EXECUTOR=thread
FREIGHT_REDIS_URL=redis://localhost:6379/0

# Storage
FREIGHT_STORAGE_BACKEND=local
FREIGHT_STORAGE_ROOT=./_storage

# Confidence bands (Enhancement #4)
FREIGHT_BAND_HIGH_MIN=0.90
FREIGHT_BAND_MEDIUM_MIN=0.75

# AI validation gate (optional — without a key the gate is skipped, items go to review)
FREIGHT_AI_PROVIDER=anthropic
FREIGHT_ANTHROPIC_API_KEY=
FREIGHT_OPENAI_API_KEY=
FREIGHT_AI_MODEL_VALIDATION=claude-opus-4-8
FREIGHT_AI_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# Embeddings / RAG — "local" needs no key/network (good for local mode)
FREIGHT_EMBEDDING_PROVIDER=local
FREIGHT_EMBEDDING_MODEL=text-embedding-3-small
FREIGHT_EMBEDDING_DIM=1536
